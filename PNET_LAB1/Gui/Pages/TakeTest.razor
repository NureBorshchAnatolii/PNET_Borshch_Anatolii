@page "/attempt/{AttemptId:guid}"
@inject HttpClient Http
@inject NavigationManager Nav
@using System.Net
@implements IDisposable

<PageTitle>Taking Test</PageTitle>

@if (_loading)
{
    <div class="centered">
        <p class="muted">Loading test...</p>
    </div>
}
else if (_error is not null)
{
    <div class="centered">
        <p class="error-text">@_error</p>
        <button class="btn" @onclick='() => Nav.NavigateTo("/tests")'>Back to Tests</button>
    </div>
}
else if (_attempt is not null)
{
    <div class="test-shell">

        <!-- Top bar -->
        <div class="topbar">
            <div class="topbar-left">
                <span class="test-title">@_attempt.TestTitle</span>
                <span class="progress-label">@(_current + 1) / @_attempt.Questions.Count</span>
            </div>
            @if (_attempt.TimeLimitMinutes.HasValue)
            {
                <div class="timer @(_timerWarning ? "timer-warn" : "")">
                    @FormatTime(_secondsLeft)
                </div>
            }
        </div>

        <!-- Progress -->
        <div class="progress-track">
            <div class="progress-fill" style="width:@((_current + 1) * 100 / _attempt.Questions.Count)%"></div>
        </div>

        <!-- Question -->
        @{
            var q = _attempt.Questions[_current];
        }
        <div class="question-wrap">
            <div class="question-meta">
                <span class="pts-tag">@q.Points pts</span>
            </div>

            <p class="question-text">@q.Text</p>

            @if (q.QuestionType.Equals("singleChoice", StringComparison.OrdinalIgnoreCase) ||
                 q.QuestionType.Equals("trueFalse", StringComparison.OrdinalIgnoreCase))
            {
                <div class="options">
                    @foreach (var a in q.Answers)
                    {
                        var selected = IsSelected(q.Id, a.Id);
                        <div class="option @(selected ? "option-active" : "")"
                             @onclick="() => SelectSingle(q.Id, a.Id)">
                            <div class="option-indicator radio @(selected ? "indicator-active" : "")"></div>
                            <span>@a.Text</span>
                        </div>
                    }
                </div>
            }
            else if (q.QuestionType.Equals("multipleChoice", StringComparison.OrdinalIgnoreCase))
            {
                <p class="hint-text">Select all that apply</p>
                <div class="options">
                    @foreach (var a in q.Answers)
                    {
                        var selected = IsSelected(q.Id, a.Id);
                        <div class="option @(selected ? "option-active" : "")"
                             @onclick="() => ToggleMultiple(q.Id, a.Id)">
                            <div class="option-indicator checkbox @(selected ? "indicator-active" : "")">
                                @if (selected)
                                {
                                    <span>✓</span>
                                }
                            </div>
                            <span>@a.Text</span>
                        </div>
                    }
                </div>
            }
            else if (q.QuestionType.Equals("text", StringComparison.OrdinalIgnoreCase))
            {
                var qId = q.Id;
                <textarea class="text-answer"
                          rows="3"
                          placeholder="Type your answer here..."
                          value="@GetText(qId)"
                          @oninput="e => SetText(qId, e.Value?.ToString() ?? string.Empty)"></textarea>
            }
        </div>

        <!-- Navigation -->
        <div class="nav-bar">
            <button class="btn btn-ghost" @onclick="Prev" disabled="@(_current == 0)">← Prev</button>

            <div class="dots">
                @for (var i = 0; i < _attempt.Questions.Count; i++)
                {
                    var idx = i;
                    var done = _answers.ContainsKey(_attempt.Questions[i].Id);
                    <span class="dot @(idx == _current ? "dot-current" : "") @(done ? "dot-done" : "")"
                          @onclick="() => _current = idx"></span>
                }
            </div>

            @if (_current < _attempt.Questions.Count - 1)
            {
                <button class="btn" @onclick="Next">Next →</button>
            }
            else
            {
                <button class="btn btn-submit" @onclick="Submit" disabled="@_submitting">
                    @(_submitting ? "Submitting..." : "Submit Test")
                </button>
            }
        </div>
    </div>
}

<style>
    .centered {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 60vh;
        gap: 1rem;
    }

    .test-shell {
        max-width: 700px;
        margin: 0 auto;
        padding-bottom: 3rem;
    }

    .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 0 .75rem;
        border-bottom: 1px solid #e9ecef;
        margin-bottom: .75rem;
    }

    .topbar-left {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .test-title {
        font-weight: 600;
        font-size: 1rem;
        color: #212529;
    }

    .progress-label {
        font-size: .82rem;
        color: #6c757d;
        background: #f1f3f5;
        padding: .2rem .6rem;
