    }

    .timer-warn {
        color: #dc3545;
    }

    .progress-track {
        height: 4px;
        background: #e9ecef;
        border-radius: 2px;
        margin-bottom: 2rem;
    }

    .progress-fill {
        height: 100%;
        background: #0d6efd;
        border-radius: 2px;
        transition: width .3s ease;
    }

    .question-wrap {
        background: #fff;
        border: 1px solid #e9ecef;
