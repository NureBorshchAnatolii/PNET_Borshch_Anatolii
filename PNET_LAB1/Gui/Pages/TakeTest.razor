        padding: 1.5rem;
        margin-bottom: 1.25rem;
    }

    .question-meta {
        display: flex;
        gap: .5rem;
        margin-bottom: 1rem;
    }

    .pts-tag {
        font-size: .75rem;
        font-weight: 600;
        background: #f1f3f5;
        color: #6c757d;
        padding: .2rem .6rem;
        border-radius: 20px;
    }

    .question-text {
        font-size: 1.05rem;
        font-weight: 500;
        color: #212529;
        line-height: 1.55;
        margin: 0 0 1.25rem;
    }

    .hint-text {
        font-size: .82rem;
        color: #6c757d;
        margin: 0 0 .75rem;
    }

    .options {
        display: flex;
        flex-direction: column;
        gap: .5rem;
    }

    .option {
        display: flex;
        align-items: center;
        gap: .75rem;
        padding: .75rem 1rem;
        border: 1.5px solid #dee2e6;
        border-radius: 8px;
        cursor: pointer;
        transition: border-color .12s, background .12s;
        user-select: none;
    }

    .option:hover {
        border-color: #86b7fe;
        background: #f8f9ff;
    }

    .option-active {
        border-color: #0d6efd !important;
        background: #e7f1ff !important;
    }

    .option-indicator {
        flex-shrink: 0;
        width: 18px;
        height: 18px;
        border: 2px solid #adb5bd;
        transition: all .12s;
    }

    .radio {
        border-radius: 50%;
    }

    .checkbox {
