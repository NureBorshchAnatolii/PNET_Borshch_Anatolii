        justify-content: flex-end;
        gap: .6rem;
        margin-top: 1.25rem;
    }

    .warn-text {
        color: #dc3545;
        display: block;
        margin-top: .25rem;
        font-size: .85rem;
    }

    .error-text {
        color: #dc3545;
        font-size: .875rem;
    }

    .muted {
        color: #6c757d;
    }
</style>

@code {
    [Parameter] public Guid AttemptId { get; set; }

    private AttemptDetailResponse? _attempt;
    private bool _loading = true;
    private bool _submitting;
    private bool _showConfirm;
    private string? _error;
    private int _current;

    private readonly Dictionary<Guid, AnswerState> _answers = new();

    private int _secondsLeft;
    private bool _timerWarning;
    private Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetAsync($"/api/attempts/{AttemptId}/detail");

            if (response.StatusCode == HttpStatusCode.NotFound)
            {
                Nav.NavigateTo($"/attempt/{AttemptId}/result", replace: true);
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                _error = $"Failed to load attempt ({(int)response.StatusCode}).";
                return;
            }

            _attempt = await response.Content.ReadFromJsonAsync<AttemptDetailResponse>();

            if (_attempt is null)
            {
                _error = "Attempt not found.";
                return;
            }

            _attempt = _attempt with
            {
                Questions = _attempt.Questions.OrderBy(q => q.Order).ToList()
            };

            if (_attempt.TimeLimitMinutes.HasValue)
            {
                _secondsLeft = _attempt.TimeLimitMinutes.Value * 60;
                _timer = new Timer(async _ =>
                {
                    _secondsLeft--;
                    _timerWarning = _secondsLeft <= 60;
                    if (_secondsLeft <= 0)
                    {
                        _timer?.Dispose();
                        await InvokeAsync(Submit);
                    }
                    else
                    {
                        await InvokeAsync(StateHasChanged);
                    }
                }, null, 1000, 1000);
            }
        }
        catch (Exception ex)
        {
            _error = $"Failed to load: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private bool IsSelected(Guid qId, Guid aId)
    {
        return _answers.TryGetValue(qId, out var s) && s.SelectedIds.Contains(aId);
    }

    private void SelectSingle(Guid qId, Guid aId)
    {
        _answers[qId] = new AnswerState { SelectedIds = new List<Guid> { aId } };
    }

    private void ToggleMultiple(Guid qId, Guid aId)
    {
        if (!_answers.ContainsKey(qId))
            _answers[qId] = new AnswerState();

        var ids = _answers[qId].SelectedIds;
        if (ids.Contains(aId)) ids.Remove(aId);
        else ids.Add(aId);
    }

    private string GetText(Guid qId)
    {
        return _answers.TryGetValue(qId, out var s) ? s.TextAnswer : string.Empty;
    }

    private void SetText(Guid qId, string value)
    {
        if (!_answers.ContainsKey(qId))
            _answers[qId] = new AnswerState();
        _answers[qId].TextAnswer = value;
    }

    private void Next()
    {
        if (_current < _attempt!.Questions.Count - 1) _current++;
    }

    private void Prev()
    {
        if (_current > 0) _current--;
    }

    private async Task Submit()
    {
        _showConfirm = false;
        _submitting = true;
        _error = null;

        try
        {
            var payload = new
            {
                answers = _attempt!.Questions.Select(q =>
                {
                    _answers.TryGetValue(q.Id, out var ans);
                    return new
                    {
                        questionId = q.Id,
                        selectedAnswerIds = ans?.SelectedIds ?? new List<Guid>(),
                        textAnswer = ans?.TextAnswer
                    };
                }).ToList()
            };

            var response = await Http.PostAsJsonAsync(
                $"/api/attempts/{AttemptId}/submit", payload);

            if (response.IsSuccessStatusCode)
            {
                Nav.NavigateTo($"/attempt/{AttemptId}/result");
                return;
            }

            if (response.StatusCode == HttpStatusCode.BadRequest)
            {
                var raw = await response.Content.ReadAsStringAsync();
                if (raw.Contains("already completed", StringComparison.OrdinalIgnoreCase))
                {
                    _timer?.Dispose();
                    Nav.NavigateTo($"/attempt/{AttemptId}/result");
                    return;
                }

                _error = raw;
            }
            else
            {
                _error = $"Submission failed ({(int)response.StatusCode}).";
            }

            _showConfirm = true;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _showConfirm = true;
        }
        finally
        {
            _submitting = false;
        }
    }

    private static string FormatTime(int seconds)
    {
        var m = seconds / 60;
        var s = seconds % 60;
        return $"{m:D2}:{s:D2}";
    }

    public void Dispose()
    {
        _timer?.Dispose();
    }

    class AnswerState
    {
        public List<Guid> SelectedIds { get; set; } = new();
        public string TextAnswer { get; set; } = string.Empty;
    }

    record AttemptDetailResponse(
        Guid AttemptId,
        Guid TestId,
        string TestTitle,
        int? TimeLimitMinutes,
        DateTime StartedAt,
        List<QuestionDto> Questions
    );

    record QuestionDto(
        Guid Id,
        string Text,
        string QuestionType,
        decimal Points,
        int Order,
        string? Explanation,
        List<AnswerDto> Answers
    );

    record AnswerDto(Guid Id, string Text, int Order);

}
