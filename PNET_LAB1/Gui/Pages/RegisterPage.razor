@page "/register"
@using System.ComponentModel.DataAnnotations
@using System.Net
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Register</PageTitle>

<div class="auth-wrapper">
    <div class="auth-card">

        <h2>Create account</h2>
        <p class="subtitle">Fill in the details below to get started</p>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert-error">@_errorMessage</div>
        }

        @if (_success)
        {
            <div class="alert-success">Account created! Redirecting to login...</div>
        }

        <EditForm Model="_model" OnValidSubmit="HandleRegister">
            <DataAnnotationsValidator/>

            <div class="field-row">
                <div class="field">
                    <label>First name</label>
                    <InputText @bind-Value="_model.FirstName" placeholder="John"/>
                    <ValidationMessage For="@(() => _model.FirstName)"/>
                </div>
                <div class="field">
                    <label>Last name</label>
                    <InputText @bind-Value="_model.LastName" placeholder="Doe"/>
                    <ValidationMessage For="@(() => _model.LastName)"/>
                </div>
            </div>

            <div class="field">
                <label>Email</label>
                <InputText @bind-Value="_model.Email" placeholder="you@example.com" type="email"/>
                <ValidationMessage For="@(() => _model.Email)"/>
            </div>

            <div class="field">
                <label>Date of birth <span class="optional">(optional)</span></label>
                <InputDate @bind-Value="_model.BirthDate"/>
            </div>

            <div class="field">
                <label>Password</label>
                <InputText @bind-Value="_model.Password" placeholder="••••••••" type="password"/>
                <ValidationMessage For="@(() => _model.Password)"/>
            </div>

            <div class="field">
                <label>Confirm password</label>
                <InputText @bind-Value="_model.ConfirmPassword" placeholder="••••••••" type="password"/>
                <ValidationMessage For="@(() => _model.ConfirmPassword)"/>
            </div>

            <button type="submit" disabled="@_isLoading">
                @(_isLoading ? "Creating account..." : "Create account")
            </button>
        </EditForm>

        <p class="footer-link">
            Already have an account? <a href="/login">Sign in</a>
        </p>

    </div>
</div>

<style>
    .auth-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f8f9fa;
        padding: 2rem 1rem;
    }

    .auth-card {
        background: #fff;
        border: 1px solid #dee2e6;
        border-radius: 8px;
        padding: 2rem;
        width: 100%;
        max-width: 420px;
    }

    .auth-card h2 {
        margin: 0 0 .25rem;
        font-size: 1.4rem;
        font-weight: 600;
        color: #212529;
    }

    .subtitle {
        color: #6c757d;
        font-size: .9rem;
        margin: 0 0 1.5rem;
    }

    .alert-error {
        background: #fff5f5;
        border: 1px solid #f5c2c7;
        color: #842029;
        border-radius: 6px;
        padding: .6rem .9rem;
        font-size: .875rem;
        margin-bottom: 1rem;
    }

    .alert-success {
        background: #f0fff4;
        border: 1px solid #b7ebc0;
        color: #1a5c2a;
        border-radius: 6px;
        padding: .6rem .9rem;
        font-size: .875rem;
        margin-bottom: 1rem;
    }

    .field-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .75rem;
    }

    .field {
        display: flex;
        flex-direction: column;
        margin-bottom: 1rem;
    }

    .field label {
        font-size: .875rem;
        font-weight: 500;
        color: #344054;
        margin-bottom: .35rem;
    }

    .field .optional {
        font-weight: 400;
        color: #6c757d;
    }

    .field input {
        border: 1px solid #ced4da;
        border-radius: 6px;
        padding: .5rem .75rem;
        font-size: .95rem;
        outline: none;
        transition: border-color .15s;
    }

    .field input:focus {
        border-color: #0d6efd;
    }

    .field .validation-message {
        color: #dc3545;
        font-size: .8rem;
        margin-top: .25rem;
    }

    button[type="submit"] {
        width: 100%;
        margin-top: .5rem;
        padding: .55rem;
        background: #0d6efd;
        color: #fff;
        border: none;
        border-radius: 6px;
        font-size: .95rem;
        font-weight: 500;
        cursor: pointer;
        transition: background .15s;
    }

    button[type="submit"]:hover:not(:disabled) {
        background: #0b5ed7;
    }

    button[type="submit"]:disabled {
        opacity: .65;
        cursor: not-allowed;
    }

    .footer-link {
        text-align: center;
        font-size: .875rem;
        color: #6c757d;
        margin: 1.25rem 0 0;
    }

    .footer-link a {
        color: #0d6efd;
        text-decoration: none;
    }

    .footer-link a:hover {
        text-decoration: underline;
    }
</style>

@code {
    private readonly RegisterModel _model = new();
    private string? _errorMessage;
    private bool _success;
    private bool _isLoading;

    private async Task HandleRegister()
    {
        _isLoading = true;
        _errorMessage = null;
        _success = false;

        try
        {
            var response = await Http.PostAsJsonAsync("/api/auth/register", new
            {
                firstName = _model.FirstName,
                lastName = _model.LastName,
                email = _model.Email,
                password = _model.Password,
                birthDate = _model.BirthDate
            });

            if (response.IsSuccessStatusCode)
            {
                _success = true;
                await Task.Delay(1500);
                Nav.NavigateTo("/login");
            }
            else if (response.StatusCode == HttpStatusCode.Conflict)
            {
                _errorMessage = "An account with this email already exists.";
            }
            else
            {
                _errorMessage = "Registration failed. Please try again.";
            }
        }
        catch
        {
            _errorMessage = "Something went wrong. Please try again.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private class RegisterModel
    {
        [Required(ErrorMessage = "First name is required")]
        public string FirstName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Last name is required")]
        public string LastName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Email is required")]
        [EmailAddress(ErrorMessage = "Enter a valid email")]
        public string Email { get; set; } = string.Empty;

        public DateTime? BirthDate { get; set; }

        [Required(ErrorMessage = "Password is required")]
        [MinLength(6, ErrorMessage = "Minimum 6 characters")]
        public string Password { get; set; } = string.Empty;

        [Required(ErrorMessage = "Please confirm your password")]
        [Compare(nameof(Password), ErrorMessage = "Passwords do not match")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }

}
