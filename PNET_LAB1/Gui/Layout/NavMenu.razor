@inject AppAuthStateProvider AuthProvider
@inject NavigationManager Nav
@using Gui.Auth
@using Microsoft.AspNetCore.Components.Authorization
@implements IDisposable

<nav class="sidebar">
    <div class="sidebar-header">
        <span class="logo">Lab 1-2</span>
    </div>

    <AuthorizeView>
        <Authorized>
            <ul class="nav-links">
                <li><NavLink href="/tests" Match="NavLinkMatch.Prefix">All Tests</NavLink></li>
                <li><NavLink href="/tests/my">My Tests</NavLink></li>
                <li><NavLink href="/tests/create">Create Test</NavLink></li>
                <li><NavLink href="/attempts/my">My Attempts</NavLink></li>
            </ul>

            <AuthorizeView Roles="Admin" Context="adminAuth">
                <div class="nav-section-title">Admin</div>
                <ul class="nav-links">
                    <li><NavLink href="/admin/users">Users</NavLink></li>
                    <li><NavLink href="/admin/categories">Categories</NavLink></li>
                    <li><NavLink href="/admin/logs">Live Logs</NavLink></li>
                </ul>
            </AuthorizeView>

            <div class="sidebar-footer">
                <span class="user-email">@_email</span>
                <button class="btn-logout" @onclick="Logout">Sign out</button>
            </div>
        </Authorized>

        <NotAuthorized>
            <ul class="nav-links">
                <li><NavLink href="/login">Sign in</NavLink></li>
                <li><NavLink href="/register">Register</NavLink></li>
            </ul>
        </NotAuthorized>
    </AuthorizeView>
</nav>

<style>
    .sidebar {
        width: 220px;
        min-height: 100vh;
        background: #fff;
        border-right: 1px solid #dee2e6;
        display: flex;
        flex-direction: column;
        padding: 1.5rem 1rem;
        position: sticky;
        top: 0;
    }

    .sidebar-header {
        margin-bottom: 2rem;
    }

    .logo {
        font-size: 1.1rem;
        font-weight: 700;
        color: #212529;
    }

    .nav-section-title {
        font-size: .7rem;
        font-weight: 600;
        text-transform: uppercase;
        color: #adb5bd;
        margin: 1.25rem 0 .5rem .5rem;
        letter-spacing: .05em;
    }

    .nav-links {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .nav-links li {
        margin-bottom: .25rem;
    }

    .nav-links a {
        display: block;
        padding: .45rem .75rem;
        border-radius: 6px;
        color: #495057;
        text-decoration: none;
        font-size: .9rem;
        transition: background .15s;
    }

    .nav-links a:hover {
        background: #f1f3f5;
        color: #212529;
    }

    .nav-links a.active {
        background: #e7f1ff;
        color: #0d6efd;
        font-weight: 500;
    }

    .sidebar-footer {
        margin-top: auto;
        padding-top: 1rem;
        border-top: 1px solid #dee2e6;
        display: flex;
        flex-direction: column;
        gap: .5rem;
    }

    .user-email {
        font-size: .78rem;
        color: #6c757d;
        word-break: break-all;
    }

    .btn-logout {
        background: none;
        border: 1px solid #dee2e6;
        border-radius: 6px;
        padding: .4rem;
        font-size: .85rem;
        color: #495057;
        cursor: pointer;
        transition: background .15s;
    }

    .btn-logout:hover {
        background: #fff5f5;
        border-color: #f5c2c7;
        color: #842029;
    }
</style>

@code {
    private string _email = "";

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthProvider.GetAuthenticationStateAsync();
        _email = state.User.FindFirst(System.IdentityModel.Tokens.Jwt.JwtRegisteredClaimNames.Email)?.Value ?? "";
        AuthProvider.AuthenticationStateChanged += OnAuthChanged;
    }

    private async void OnAuthChanged(Task<AuthenticationState> task)
    {
        var state = await task;
        _email = state.User.FindFirst(System.IdentityModel.Tokens.Jwt.JwtRegisteredClaimNames.Email)?.Value ?? "";
        await InvokeAsync(StateHasChanged);
    }

    private async Task Logout()
    {
        await AuthProvider.MarkUserAsLoggedOutAsync();
        Nav.NavigateTo("/login");
    }

    public void Dispose() =>
        AuthProvider.AuthenticationStateChanged -= OnAuthChanged;
}